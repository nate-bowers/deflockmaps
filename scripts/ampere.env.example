# Copy to scripts/ampere.env and fill in. Find OCIDs with:
#   bash scripts/ampere-watch.sh --discover
# ampere.env is gitignored (it's just OCIDs, but keep it out of the repo).

# Your compartment OCID (or tenancy OCID for the root compartment).
COMPARTMENT_ID=ocid1.compartment.oc1..xxxxx

# A PUBLIC subnet in your VCN (create a VCN with the "Internet-connectivity" wizard).
SUBNET_ID=ocid1.subnet.oc1.xxx.xxxxx

# An ARM (aarch64) image — e.g. Ubuntu 22.04 aarch64. --discover lists current OCIDs.
IMAGE_ID=ocid1.image.oc1.xxx.xxxxx

# Public key authorized for SSH on the new box.
SSH_KEY_FILE=/Users/natebowers/.ssh/id_ed25519.pub

# Comma-separated availability domains (--discover lists them). More ADs = more
# chances each round. Single-AD regions will just have one.
ADS=AbCd:US-SANJOSE-1-AD-1

# --- optional overrides (defaults are the full free-tier allotment) ---
# SHAPE=VM.Standard.A1.Flex
# OCPUS=4
# MEM_GB=24
# BOOT_GB=50
# DISPLAY_NAME=deflock-valhalla-a1
# INTERVAL=120
# NOTIFY_WEBHOOK=https://hooks.slack.com/services/...   # optional ping on success
