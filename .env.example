# Routing engine — point this at your hosted Valhalla (see DEPLOY.md).
# Local default is http://localhost:8002 if unset.
VALHALLA_URL=https://your-valhalla-host.example.com

# Camera dataset — public URL of the refreshable cameras.json (Vercel Blob).
# If unset, the app serves the bundled snapshot in data/cameras.json.
CAMERAS_URL=

# Camera refresh cron (optional, production only):
# CRON_SECRET is any random string; Vercel sends it as a Bearer token.
# BLOB_READ_WRITE_TOKEN is added automatically when you connect a Vercel Blob store.
CRON_SECRET=
BLOB_READ_WRITE_TOKEN=
