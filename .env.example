# Routing engine — point this at your hosted Valhalla (see DEPLOY.md).
# Local default is http://localhost:8002 if unset. Used by the bundled greedy
# fallback planner; the graph planner service does not need it.
VALHALLA_URL=https://your-valhalla-host.example.com

# Camera-avoidance graph planner service (server/planner.mts) — point this at the
# always-on box that runs it (e.g. http://<engine-ip>:8090). When set, /api/route
# uses it (single-pass λ-sweep over a camera-penalized road graph, reaches the
# fewest-cameras/camera-free floor); when unset or unreachable it falls back to
# the bundled greedy planner. See DEPLOY.md.
PLANNER_URL=

# Road-graph source the planner service compiles at startup (server-side only).
# Generate with: node scripts/fetch-road-graph.mjs  (default ./road-ways.json)
ROAD_GRAPH_WAYS=road-ways.json

# Camera dataset — public URL of the refreshable cameras.json (Vercel Blob).
# If unset, the app serves the bundled snapshot in data/cameras.json.
CAMERAS_URL=

# Camera refresh cron (optional, production only):
# CRON_SECRET is any random string; Vercel sends it as a Bearer token.
# BLOB_READ_WRITE_TOKEN is added automatically when you connect a Vercel Blob store.
CRON_SECRET=
BLOB_READ_WRITE_TOKEN=
